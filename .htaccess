<IfModule mod_headers.c>
    # Dynamically reflect the Origin header. NEVER use "*" when credentials are true!
    SetEnvIf Origin "^(.+)$" ORIGIN_DOMAIN=$1
    Header always set Access-Control-Allow-Origin "%{ORIGIN_DOMAIN}e" env=ORIGIN_DOMAIN
    
    # Allow common HTTP methods
    Header always set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS, PATCH"
    
    # Allow common headers
    Header always set Access-Control-Allow-Headers "Origin, X-Requested-With, Content-Type, Accept, Authorization, X-Auth-Token, X-Conversation-Id"
    
    # Expose custom headers to the client
    Header always set Access-Control-Expose-Headers "X-Conversation-Id, X-Total-Count, X-Page-Count"
    
    # Allow credentials
    Header always set Access-Control-Allow-Credentials "true"
    
    # Cache preflight requests for 1 hour
    Header always set Access-Control-Max-Age "3600"
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # ── SHORT LINK REDIRECTS ──
    # Priority 1: Handle /go/slug
    RewriteRule ^go/([a-zA-Z0-9_-]+)$ /mail_api/go.php?s=$1 [L,QSA]
    
    # Priority 2: Handle /mail_api/go/slug (fallback)
    RewriteRule ^mail_api/go/([a-zA-Z0-9_-]+)$ /mail_api/go.php?s=$1 [L,QSA]

    # Respond to OPTIONS requests immediately
    RewriteCond %{REQUEST_METHOD} OPTIONS
    RewriteRule ^(.*)$ $1 [R=200,L]

    # ── SPA FALLBACK (React Router) ──
    # If the request is not for a real file or directory...
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    # ...and it's not an API or uploads path...
    RewriteCond %{REQUEST_URI} !^/(api|mail_api|uploadss)/ [NC]
    # ...serve index.html instead so React Router can handle the path (e.g. /admin/workspace)
    RewriteRule ^(.*)$ index.html [L,QSA]
</IfModule>

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
</IfModule>

<IfModule mod_headers.c>
    # Prevent MIME type sniffing
    Header always set X-Content-Type-Options "nosniff"
    
    # Enable XSS protection
    Header always set X-XSS-Protection "1; mode=block"
    
    # Prevent clickjacking
    Header always set X-Frame-Options "SAMEORIGIN"
</IfModule>

# ─── PROTECT LOG FILES AND SENSITIVE SCRIPTS ─────────────────────────────────
<FilesMatch "\.(log|lock|sql|bak|tmp|md)$">
    Order deny,allow
    Deny from all
</FilesMatch>

<FilesMatch "^(diagnostic_tracking|db_schema_check|db_optimization_check|autoflow_health|system_health_check|system_perf_check|generate_diagnostic_log|recover|recover2|recover3|hard_clean_logs|clear_pauses|admin_fix_bounce|analyze_|trace_|forms_debug|timer_debug|worker_campaign_dryrun|campaign_audit|journey_audit|perf_audit|quick_check|debug_ai|check\.php|test_sync|test_states)\.php$">
    Order deny,allow
    Deny from all
</FilesMatch>
