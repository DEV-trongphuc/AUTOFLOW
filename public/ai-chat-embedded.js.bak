            const finalText = correctVoiceText(fullTranscript.trim());

            // Show "TÌM THẤY THÔNG TIN" UI for iOS matching Google STT style
            if (State.isLiveMode) {
                const wrapper = document.getElementById('mf-lyric-wrapper');
